# =============================================================
# RealE Linux — Environment Configuration
# Copyright (c) Joe Wease, RealE
# Copy to /opt/reale-auth/.env inside the container
# Or set as RunPod environment variables
# =============================================================

# ── Solana ────────────────────────────────────────────────────
# Your SPL token mint address (create via Metaplex or spl-token CLI)
REALE_TOKEN_MINT=YOUR_SPL_TOKEN_MINT_ADDRESS

# Minimum raw token amount required (accounts for decimals)
# Example: if 6 decimals, 1 token = 1000000
REQUIRED_TOKEN_AMOUNT=1000000

# RPC endpoint — use a paid RPC for production (Helius, QuickNode, etc.)
SOLANA_RPC=https://api.mainnet-beta.solana.com
# For devnet testing:
# SOLANA_RPC=https://api.devnet.solana.com

# ── Auth ──────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# Session duration in hours
SESSION_HOURS=4

# ── Server ────────────────────────────────────────────────────
AUTH_PORT=3000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────
# Set to your RunPod public URL in production
ALLOWED_ORIGIN=*

# ── VNC ──────────────────────────────────────────────────────
VNC_RESOLUTION=1280x800
VNC_DEPTH=24
